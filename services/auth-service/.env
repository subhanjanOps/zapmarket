# Auth Service Environment Variables

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=zapuser
DB_PASSWORD=zappass123
DB_NAME=userauth

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_REFRESH_SECRET_KEY=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=7

# OAuth2 - Google
OAUTH2_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH2_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_GOOGLE_REDIRECT_URL=http://localhost:8080/auth/oauth/google/callback

# OAuth2 - Facebook
OAUTH2_FACEBOOK_CLIENT_ID=your-facebook-client-id
OAUTH2_FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
OAUTH2_FACEBOOK_REDIRECT_URL=http://localhost:8080/auth/oauth/facebook/callback

# Service Configuration
HTTP_PORT=8080
GRPC_PORT=50051
APP_ENV=development
